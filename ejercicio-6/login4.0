                        if metodo not in ("e", "t", "E", "T"):
                            print("Ingresa un metodo de pago valido")
                            continue

                        if dia == "6" or dia == "7":
                            print("se te aplicara un recargo del 10%")
                            recargo = servicio/100 * 10
                            servicio += recargo 
                            print("tu cuenta ahora es de ", servicio)

                        servicio_base = servicio

                        
                        if 0 <= edad_1 <= 12:
                            descuento =  servicio * 0.5
                            servicio = servicio - descuento 
                            porcentaje =  porcentaje + 50
                            print(" El descuento aplicado fue de 50%")
                            print("El total a pagar ahora es: ", servicio)
                        elif 13 <= edad_1 <= 17:
                            descuento = servicio * 0.2
                            servicio = servicio - descuento
                            porcentaje = porcentaje + 20
                            print("el descuento aplicado fue de 20%")
                            print("El total a pagar ahora es: ", servicio)
                        elif 65<= edad_1 <= 120:
                            descuento = servicio * 0.30
                            servicio = servicio - descuento
                            porcentaje = porcentaje + 30
                            print("El descuento aplicado fue de 30%")
                            print("El total a pagar ahora es: ", servicio)

                        if estudiante == "s" or estudiante == "S":
                            if edad_1 >= 13:
                                print("Aplicas descuento por ser estudiante y tener mas de 13 años")
                                descuento = servicio * 0.15
                                servicio = servicio - descuento
                                porcentaje = porcentaje + 15
                                print("El descuento aplicado fue de 15%")
                                print("El total a pagar ahora es: ", servicio)
                            else:
                                    print("Eres estudiante, pero no aplicas descuento por ser menos a 13 años")
                        
                        if miembro == "s" or miembro == "S":
                            print("Aplicas descuento por ser miembro")
                            descuento = servicio * 0.10
                            servicio = servicio - descuento
                            porcentaje = porcentaje + 10
                            print("El descuento aplicado es 10%")
                            print("El total a pagar ahora es: ", servicio)

                        if metodo == "e" or metodo =="E":
                            print("Aplicaste un metodo por pagar en efectivo")
                            descuento = servicio * 0.05
                            servicio = servicio - descuento
                            porcentaje = porcentaje + 5
                            print("El descuento aplicado fue de 5%")
                            print("El total a pagar ahora es: ", servicio)

                        # --- AJUSTE FINAL (SIEMPRE) ---
                        if porcentaje > 60:
                            print("Tu descuento era de:", porcentaje, "% pero el maximo es 60%")

                            porcentaje = min(porcentaje, 60)

                            descuento = servicio_base * (porcentaje / 100)
                            servicio = servicio_base - descuento

                            print("Descuento final aplicado:", porcentaje, "%")
                            print("Monto de descuento final:", descuento)
                            print("TOTAL A PAGAR:", servicio)

                            acceso_3 = 0
                            
                 case 4:
                      acceso = 0
                 case 5:
                    print("todo termino gracias por usar mi programa")
                    acceso = -1
                    break 
                 case _:
                    print("opcion no valida")
                    
        if acceso == -1:
         break 
    else:
          print("Usuario o Contrseña incorrectos")
          intentos +=1

if intentos >=3:
    print("Intentos caducados vuelve a intenterlo mas tarde")
